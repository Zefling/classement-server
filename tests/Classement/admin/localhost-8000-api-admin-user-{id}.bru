meta {
  name: /api/admin/user/{id}
  type: http
  seq: 13
}

post {
  url: {{base_url}}/api/admin/user/{{userId}}
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
      "username": "dunglas18--",
      "email": "dunglas@example.com",
      "password": "MyPassword"
  }
}

vars:pre-request {
  userId: 1
}

assert {
  res.status: eq 200
  res.body.status: eq OK
  res.body.message: isDefined
}

docs {
  # Admin: Update User
  
  Updates user information as administrator.
  
  ## Authentication
  
  Requires admin privileges with valid `X-AUTH-TOKEN`.
  
  ## Parameters
  
  - `{id}`: User ID
  
  ## Request Body
  
  - `username`: New username (optional)
  - `email`: New email (optional)
  - `password`: New password (optional)
  
  ## Response
  
  Returns updated user information.
  
  ## Notes
  
  - Admin can update any user
  - Password will be hashed
  - Email and username must remain unique
}

settings {
  encodeUrl: true
}
