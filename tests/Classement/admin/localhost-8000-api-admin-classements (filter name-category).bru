meta {
  name: /api/admin/classements (filter name/category)
  type: http
  seq: 5
}

get {
  url: {{base_url}}/api/admin/classements?page=1&name=Princes&category=anime
  body: json
  auth: inherit
}

params:query {
  page: 1
  name: Princes
  category: anime
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

settings {
  encodeUrl: true
}
