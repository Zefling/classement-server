meta {
  name: /api/admin/classements (sort name)
  type: http
  seq: 6
}

get {
  url: {{base_url}}/api/admin/classements?order=name&direction=ASC 
  body: json
  auth: inherit
}

docs {
  # Admin - List Classements Sorted by Name
  
  Retrieves a list of all classements sorted alphabetically by name.
  
  ## Authentication
  Requires admin authentication via X-AUTH-TOKEN header.
  
  ## Query Parameters
  - `order`: Field to sort by (value: "name")
  - `direction`: Sort direction - "ASC" for ascending, "DESC" for descending
  
  ## Response
  Returns a list of classements sorted alphabetically by their name in the specified direction.
  
  ## Use Cases
  - Admin dashboard with alphabetical sorting
  - Finding classements by name quickly
  - Organizing content alphabetically for review
}

params:query {
  order: name
  direction: ASC 
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

settings {
  encodeUrl: true
}

assert {
  res.status: eq 200
  res.body.classements: isDefined
  res.body.classements: isArray
}
