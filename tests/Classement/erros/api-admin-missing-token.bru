meta {
  name: Missing token - Admin endpoint
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/admin/classements
  body: json
  auth: none
}

assert {
  res.status: eq 401
  res.body.errorCode: eq 1030
  res.body.errorMessage: eq Invalid credentials.
  res.body.status: eq KO
}

tests {
  test("Should return 401 when token is missing", function() {
    expect(res.status).to.equal(401);
  });
  
  test("Should return error code 1030", function() {
    expect(res.body.errorCode).to.equal(1030);
  });
  
  test("Should return KO status", function() {
    expect(res.body.status).to.equal("KO");
  });
  
  test("Should not return stack trace", function() {
    expect(res.body).to.not.have.property("trace");
    expect(res.body).to.not.have.property("@context");
  });
}

docs {
  # Test: Missing Token - Admin Endpoint
  
  Tests that admin endpoints return proper JSON error format when no token is provided.
  
  ## Expected Behavior
  
  - Returns 401 Unauthorized
  - Returns error code 1030 (INVALID_TOKEN)
  - Returns JSON format (not stack trace)
  - Message: "Invalid credentials."
  
  ## Security
  
  This test ensures that:
  - Endpoints requiring authentication reject requests without tokens
  - Error format is consistent
  - No stack trace is exposed
}
