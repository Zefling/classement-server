meta {
  name: /api/template/{id}
  type: http
  seq: 22
}

get {
  url: {{base_url}}/api/classements/template/{{templateId}}
  body: none
  auth: inherit
}

docs {
  # Get Classement Template
  
  Retrieves a classement template by its unique ID. Templates are pre-configured classement structures that can be used to create new classements.
  
  ## Authentication
  Optional - can be accessed by authenticated or anonymous users.
  
  ## URL Parameters
  - `id`: The unique template identifier (hash)
  
  ## Response
  Returns the template data including structure, items, and configuration that can be used to initialize a new classement.
  
  ## Use Cases
  - Loading a template to create a new classement based on it
  - Previewing template structure before use
  - Template browsing and selection
}

vars:pre-request {
  templateId: cd8dbbe748067b6ad749764db38d56f1afc77aff
}

settings {
  encodeUrl: true
  timeout: 0
}

assert {
  res.status: eq 200
  res.body.template: isDefined
  res.body.template.id: isDefined
}
