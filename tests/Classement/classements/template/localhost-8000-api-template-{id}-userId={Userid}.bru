meta {
  name: /api/template/{id}?userId={Userid}
  type: http
  seq: 26
}

get {
  url: {{base_url}}/api/classements/template/{{templateId}}?userId={{userId}}
  body: none
  auth: inherit
}

params:query {
  userId: {{userId}}
}

docs {
  # Get Template by ID with User Context
  
  Retrieves a classement template with optional user-specific context for personalization.
  
  ## Parameters
  - `templateId`: The unique identifier of the template
  - `userId`: (Query parameter) Optional user ID for personalized template data
  
  ## Response
  Returns the template structure including default groups, options, and configuration that can be used to create new classements.
  
  ## Use Cases
  - Loading templates for creating new classements
  - Retrieving user-specific template variations
  - Cloning existing classement structures
}

assert {
  res.status: eq 200
  res.body: isDefined
}

vars:pre-request {
  templateId: cd8dbbe748067b6ad749764db38d56f1afc77aff
  userId: 17
}

settings {
  encodeUrl: true
  timeout: 0
}
