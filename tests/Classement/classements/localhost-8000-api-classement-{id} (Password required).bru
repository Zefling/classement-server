meta {
  name: /api/classement/{id} (Password required)
  type: http
  seq: 11
}

get {
  url: {{base_url}}/api/classement/{{classementId}}
  body: none
  auth: inherit
}

docs {
  # Get Password-Protected Classement
  
  Retrieves a classement that is protected by a password. The password must be provided in the X-PASSWORD header.
  
  ## Authentication
  Optional user authentication, but password is required via X-PASSWORD header.
  
  ## URL Parameters
  - `id`: The unique classement identifier (hash)
  
  ## Headers
  - `X-PASSWORD`: The password required to access this classement
  
  ## Response
  Returns the full classement data if the correct password is provided.
  
  ## Error Responses
  - 401 Unauthorized: If password is missing or incorrect
  - 404 Not Found: If classement doesn't exist
  
  ## Use Cases
  - Accessing private/restricted classements
  - Password-protected content viewing
  - Secure classement sharing
}

headers {
  X-PASSWORD: {{password}}
}

vars:pre-request {
  classementId: 18f3d0d756599b74855e88d5ba85102e000304f7
  password: test
}

settings {
  encodeUrl: true
  timeout: 0
}

assert {
  res.status: eq 200
  res.body.classement: isDefined
  res.body.classement.id: isDefined
  res.body.classement.name: isDefined
}
