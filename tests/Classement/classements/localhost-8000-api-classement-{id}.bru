meta {
  name: /api/classement/{id}
  type: http
  seq: 8
}

get {
  url: {{base_url}}/api/classement/{{classementId}}
  body: none
  auth: inherit
}

vars:pre-request {
  classementId: d62e29461ecde561ba3c64ccdae3d1a8fd1313d2
}

docs {
  # Get Classement by ID
  
  Retrieves a specific classement by its unique identifier.
  
  ## Parameters
  
  - `{id}`: Classement unique ID (hash)
  
  ## Response
  
  Returns complete classement data:
  - Name, category, mode
  - Visual configuration (options)
  - Groups/tiers with items
  - Banner image
  - Owner information
  - Creation/modification dates
  - Vote statistics
  
  ## Access
  
  - Public classements: No authentication required
  - Password-protected: Requires password
  - Private: Requires authentication and ownership
}

settings {
  encodeUrl: true
  timeout: 0
}
