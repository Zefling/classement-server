meta {
  name: /api/classement/{id}?history={history}
  type: http
  seq: 10
}

get {
  url: {{base_url}}/api/classement/df968e8f659d9ddaf6fe6b51346c66ee77195fb7?history=3
  body: none
  auth: inherit
}

docs {
  # Get Specific Classement History Version
  
  Retrieves a specific historical version of a classement by its history number.
  
  ## Authentication
  Optional - can be accessed by authenticated or anonymous users.
  
  ## URL Parameters
  - `id`: The unique classement identifier (hash)
  
  ## Query Parameters
  - `history`: The history version number to retrieve (e.g., 1, 2, 3...)
  
  ## Response
  Returns the classement data as it existed at the specified history version, allowing users to view previous states of the classement.
  
  ## Use Cases
  - Viewing how a classement looked at a specific point in time
  - Comparing different versions
  - Restoring or referencing previous versions
  - Historical analysis of ranking changes
}

params:query {
  history: 3
}

settings {
  encodeUrl: true
  timeout: 0
}

assert {
  res.status: eq 200
  res.body.classement: isDefined
  res.body.classement.id: isDefined
  res.body.classement.history: isDefined
}
