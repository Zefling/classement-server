meta {
  name: /api/user/update/email
  type: http
  seq: 8
}

post {
  url: {{base_url}}/api/user/update/email
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
      "emailOld": "dunglas@example10b.com",
      "emailNew": "dunglas@example10c.com"
  }
}

docs {
  # Update Email Address
  
  Updates the current user's email address.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Request Body
  
  - `emailOld`: Current email address (for verification)
  - `emailNew`: New email address
  
  ## Response
  
  Returns updated user information.
  
  ## Validation
  
  - Old email must match current email
  - New email must be valid format
  - New email must be unique
  - May require email verification
}

settings {
  encodeUrl: true
}
