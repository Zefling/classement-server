meta {
  name: /api/profile/{id}
  type: http
  seq: 15
}

get {
  url: {{base_url}}/api/profile/zefling4
  body: none
  auth: inherit
}

docs {
  # Get User Profile
  
  Retrieves public profile information for a specific user.
  
  ## Parameters
  
  - `{id}`: Username or user ID
  
  ## Response
  
  Returns public user information:
  - Username
  - Avatar
  - Registration date
  - Public statistics (classements created, etc.)
  
  ## Notes
  
  - No authentication required
  - Only public information is returned
  - Private user data is not exposed
}

settings {
  encodeUrl: true
}
