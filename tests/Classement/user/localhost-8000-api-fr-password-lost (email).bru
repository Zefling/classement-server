meta {
  name: /api/fr/password-lost (email)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/fr/password-lost
  body: json
  auth: inherit
}

headers {
  ~Language: fr
}

body:json {
  {
      "identifier": "zefling@ikilote.net"
  }
}

docs {
  # Password Reset Request
  
  Initiates password reset process by email.
  
  ## Request Body
  
  - `identifier`: Email address or username
  
  ## Response
  
  Returns success confirmation. Password reset email will be sent.
  
  ## Process
  
  1. User submits email/username
  2. System sends reset link to registered email
  3. User clicks link to set new password
  
  ## Notes
  
  - Endpoint is localized (fr = French)
  - Reset link expires after a certain time
  - For security, response is same whether user exists or not
}

settings {
  encodeUrl: true
}
