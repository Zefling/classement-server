meta {
  name: /api/user/update/username
  type: http
  seq: 9
}

post {
  url: {{base_url}}/api/user/update/username
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
      "username": "dunglas1882"
  }
}

docs {
  # Update Username
  
  Updates the current user's username.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Request Body
  
  - `username`: New username (must be unique)
  
  ## Response
  
  Returns updated user information.
  
  ## Validation
  
  - Username must be unique
  - Must meet minimum length requirements
  - Cannot contain special characters (depends on server rules)
}

settings {
  encodeUrl: true
}
