meta {
  name: /api/user/update/password
  type: http
  seq: 12
}

post {
  url: {{base_url}}/api/user/update/password
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
      "passwordOld": "MyPassword",
      "passwordNew": "MyPassword2"
  }
}

settings {
  encodeUrl: true
}
