meta {
  name: /api/logout
  type: http
  seq: 17
}

delete {
  url: {{base_url}}/api/logout
  body: none
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Logout User
  
  Logs out the current user and invalidates the authentication token.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Response
  
  Returns success confirmation. The token will no longer be valid after this request.
  
  ## Notes
  
  - Token becomes invalid immediately
  - User must login again to get a new token
}
