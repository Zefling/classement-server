meta {
  name: /api/themes (user)
  type: http
  seq: 7
}

get {
  url: {{base_url}}/api/themes?user={{userId}}
  body: none
  auth: inherit
}

docs {
  # Get Themes by User
  
  Retrieves all themes created by a specific user.
  
  ## Authentication
  Optional - can be accessed by authenticated or anonymous users.
  
  ## Query Parameters
  - `user`: The user ID to filter themes by
  
  ## Response
  Returns a list of custom themes created by the specified user.
  
  ## Use Cases
  - Viewing a user's custom theme collection
  - User profile page showing their created themes
  - Browsing themes from a specific creator
}

params:query {
  user: {{userId}}
}

vars:pre-request {
  userId: 31
}

settings {
  encodeUrl: true
}

assert {
  res.status: eq 200
  res.body: isDefined
  res.body: isArray
}
