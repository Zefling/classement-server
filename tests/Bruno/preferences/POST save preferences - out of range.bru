meta {
  name: POST /api/preferences - Out of Range
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/preferences
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
    "nameCopy": true,
    "newColor": "mixed",
    "newLine": "below",
    "lineOption": "auto",
    "mode": "default",
    "autoResize": "500×500",
    "pageSize": 20,
    "mainMenuReduce": false,
    "emojiList": ["😀"],
    "zoomMobile": 0,
    "adult": false,
    "advancedOptions": true,
    "advancedFork": false,
    "authApiKeys": {
      "imdb": "test-key"
    },
    "api": {
      "anilist": true
    }
  }
}

docs {
  # Save Preferences - Out of Range Value
  
  Tests that saving preferences with a value outside allowed range returns 400 Bad Request.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Request Body
  
  The `zoomMobile` field is set to 0, which is below the minimum allowed value of 50.
  
  ## Expected Response
  
  - Status: 400 Bad Request
  - Body: Error message with validation details indicating value is out of range
  - errorCode: INVALID_DATA
  
  ## Validates Requirements
  
  - 2.5: Validation fails for out-of-range values
  - 2.8: Schema enforces minimum/maximum constraints (zoomMobile: 50-200)
}

settings {
  encodeUrl: true
}

assert {
  res.status: eq 400
  res.body.status: eq KO
  res.body.errorMessage: contains JsonSchema Error
}
