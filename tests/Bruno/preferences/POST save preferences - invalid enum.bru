meta {
  name: POST /api/preferences - Invalid Enum
  type: http
  seq: 6
}

post {
  url: {{base_url}}/api/preferences
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
    "nameCopy": true,
    "newColor": "invalid",
    "newLine": "below",
    "lineOption": "auto",
    "mode": "default",
    "autoResize": "500×500",
    "pageSize": 20,
    "mainMenuReduce": false,
    "emojiList": ["😀"],
    "zoomMobile": 100,
    "adult": false,
    "advancedOptions": true,
    "advancedFork": false,
    "authApiKeys": {
      "imdb": "test-key"
    },
    "api": {
      "anilist": true
    }
  }
}

docs {
  # Save Preferences - Invalid Enum Value
  
  Tests that saving preferences with an invalid enum value returns 400 Bad Request.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Request Body
  
  The `newColor` field is set to "invalid", which is not one of the allowed enum values ("mixed" or "same").
  
  ## Expected Response
  
  - Status: 400 Bad Request
  - Body: Error message with validation details indicating invalid enum value
  - errorCode: INVALID_DATA
  
  ## Validates Requirements
  
  - 2.5: Validation fails for invalid enum values
  - 2.10: Schema enforces enum constraints
}

settings {
  encodeUrl: true
}

assert {
  res.status: eq 400
  res.body.status: eq KO
  res.body.errorMessage: contains JsonSchema Error
}
