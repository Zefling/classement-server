meta {
  name: POST /api/preferences - Update Existing
  type: http
  seq: 7
}

post {
  url: {{base_url}}/api/preferences
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
    "interfaceLanguage": "en",
    "interfaceTheme": "light",
    "nameCopy": false,
    "newColor": "same",
    "newLine": "above",
    "lineOption": "reduce",
    "mode": "advanced",
    "autoResize": "300×300",
    "theme": "modern",
    "pageSize": 50,
    "mainMenuReduce": true,
    "emojiList": ["🚀", "⭐", "💡"],
    "zoomMobile": 150,
    "adult": true,
    "advancedOptions": false,
