meta {
  name: /api/classements/last
  type: http
  seq: 22
}

get {
  url: {{base_url}}/api/classements/last?limit=8
  body: none
  auth: inherit
}

params:query {
  limit: 8
}

docs {
  # Get Latest Classements
  
  Retrieves the most recently created or updated classements.
  
  ## Query Parameters
  
  - `limit`: Maximum number of results (default: 8)
  
  ## Response
  
  Returns array of recent classements with:
  - Basic information (name, category, mode)
  - Thumbnail/banner
  - Owner
  - Creation date
  - Vote count
  
  ## Use Cases
  
  - Homepage "Latest" section
  - Activity feed
  - Discovery features
}

settings {
  encodeUrl: true
  timeout: 0
}
