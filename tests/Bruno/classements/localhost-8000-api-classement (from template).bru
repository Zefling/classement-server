meta {
  name: /api/classement (from template)
  type: http
  seq: 6
}

post {
  url: {{base_url}}/api/classement
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

docs {
  # Create Classement from Template
  
  Creates a new classement based on an existing template, inheriting its structure and configuration.
  
  ## Authentication
  Requires valid authentication token in X-AUTH-TOKEN header.
  
  ## Request Body
  - `name`: Title for the new classement
  - `category`: Category classification
  - `mode`: Display mode
  - `templateId`: ID of the template to use as base
  - `banner`: Banner image (URL or base64)
  - `data`: Ranking data (can override template defaults)
  
  ## Response
  Returns the newly created classement with all inherited and customized properties.
  
  ## Use Cases
  - Quick creation from predefined structures
  - Maintaining consistent formatting across rankings
  - Reusing popular ranking layouts
}

assert {
  res.status: eq 200
  res.body.status: eq OK
  res.body.classement: isDefined
  res.body.classement.id: isDefined
}

