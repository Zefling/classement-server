meta {
  name: /api/user
  type: http
  seq: 18
}

delete {
  url: {{base_url}}/api/user
  body: none
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  # Delete User Account
  
  Permanently deletes the current user's account.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Response
  
  Returns confirmation of account deletion.
  
  ## Warning
  
  - This action is irreversible
  - All user data will be permanently deleted
  - Associated classements may be affected
}
