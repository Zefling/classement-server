meta {
  name: /api/user/update/password
  type: http
  seq: 12
}

post {
  url: {{base_url}}/api/user/update/password
  body: json
  auth: inherit
}

headers {
  X-AUTH-TOKEN: {{auth_token}}
}

body:json {
  {
      "passwordOld": "MyPassword",
      "passwordNew": "MyPassword2"
  }
}

docs {
  # Update Password
  
  Updates the current user's password.
  
  ## Authentication
  
  Requires valid `X-AUTH-TOKEN` header.
  
  ## Request Body
  
  - `passwordOld`: Current password (for verification)
  - `passwordNew`: New password
  
  ## Response
  
  Returns success confirmation.
  
  ## Security
  
  - Old password must be correct
  - New password must meet security requirements
  - User remains logged in after password change
}

settings {
  encodeUrl: true
}
