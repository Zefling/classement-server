meta {
  name: /api/login
  type: http
  seq: 6
}

post {
  url: {{base_url}}/api/login
  body: json
  auth: inherit
}

docs {
  # User Login
  
  Authenticates a user and returns an authentication token.
  
  ## Authentication
  No authentication required (this is the login endpoint).
  
  ## Request Body
  - `username`: User's username
  - `password`: User's password
  
  ## Response
  Returns a success message with an authentication token that should be used for subsequent authenticated requests.
  
  ## Post-Response Script
  Automatically updates the `auth_token` environment variable with the returned token for use in other requests.
  
  ## Use Cases
  - User authentication
  - Obtaining access token for API requests
  - Session initialization
}

body:json {
  {
      "username": "dunglas1882",
      "password": "donkTop1234!"
  }
}

script:post-response {
  // Auto-update auth_token after successful login
  if (res.status === 200 && res.body.message && res.body.message.token) {
    bru.setEnvVar("auth_token", res.body.message.token);
    console.log("Token updated:", res.body.message.token);
  }
}

settings {
  encodeUrl: true
}

assert {
  res.status: eq 200
  res.body.message: isDefined
  res.body.message.token: isDefined
}
