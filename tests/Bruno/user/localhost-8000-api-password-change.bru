meta {
  name: /api/password-change
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/password-change
  body: json
  auth: inherit
}

docs {
  # Change Password with Token
  
  Completes the password reset process using a reset token.
  
  ## Authentication
  Requires authentication via X-AUTH-TOKEN header.
  
  ## Request Body
  - `token`: The password reset token received via email
  - `password`: The new password
  
  ## Response
  Returns confirmation of successful password change.
  
  ## Notes
  - The token is single-use and expires after a certain time
  - The new password must meet security requirements
  
  ## Use Cases
  - Completing password reset flow
  - Setting new password after receiving reset email
}

headers {
  ~Language: fr
}

body:json {
  {
      "token": "588f17cl2zwogg0wwc408soo4s0os4s",
      "password": "NewPassword2"
  }
}

assert {
  res.status: eq 200
  res.body.message: isDefined
}

settings {
  encodeUrl: true
}
