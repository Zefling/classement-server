meta {
  name: /api/fr/password-lost (username)
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/fr/password-lost
  body: json
  auth: inherit
}

docs {
  # Password Reset Request (Username)
  
  Initiates a password reset process using a username identifier.
  
  ## Authentication
  Requires authentication via X-AUTH-TOKEN header.
  
  ## Request Body
  - `identifier`: The username of the account
  
  ## Response
  Returns confirmation that a password reset email has been sent (if the username exists).
  
  ## Notes
  - For security, the response doesn't reveal whether the username exists
  - A reset token is sent to the email associated with the username
  - The endpoint is localized (French version)
  
  ## Use Cases
  - User forgot password and remembers username
  - Password recovery flow
}

headers {
  ~Language: fr
}

body:json {
  {
      "identifier": "zefling"
  }
}

assert {
  res.status: eq 200
  res.body.message: isDefined
}

settings {
  encodeUrl: true
}
